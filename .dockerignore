# Keep the image clean: exclude VCS, build leftovers, and runtime data.
.git
.github
cypress*
*.log
# Compose/docs aren't needed inside the runtime image
docker-compose.yml
SETUP.md
# Runtime cache (recreated in the Dockerfile) and uploaded files
cache/
files/
# Never bake a real config (with secrets) into the image — the entrypoint
# renders config.inc.php from environment at boot.
config.inc.php
